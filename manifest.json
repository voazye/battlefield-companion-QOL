{
  "manifest_version": 2,
  "name": "Battlefield Emblem Rotate Fix",
  "version": "1.0",
  "description": "Aktiviert das Rotier-Handle im Battlefield Companion Emblem-Editor, das dort standardmäßig deaktiviert ist.",

  "permissions": [
    "https://companion.battlefield.com/*"
  ],

  "content_scripts": [
    {
      "matches": ["https://companion.battlefield.com/*"],
      "js": ["inject.js"],
      "run_at": "document_start",
      "all_frames": true
    }
  ],

  "browser_action": {
    "default_icon": "icon.png",
    "default_title": "Emblem Rotate Fix – Status"
  },

  "browser_specific_settings": {
    "gecko": {
      "id": "bf-emblem-rotate-fix@local.test",
      "strict_min_version": "140.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  }
}
